VITE_API_BASE_URL=http://localhost:8000
# On Vercel, the frontend and API are deployed to the same project/domain
# (see vercel.json + wiki/deploy-vercel.md). Client calls already include
# the /api prefix themselves (see src/api/client.ts), so set this to an
# EMPTY string there — not "/api" (that would double up to /api/api/...).
# Same-origin, so no CORS config is needed on that path either.
