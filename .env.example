# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hsk_frequency
DB_USER=hsk_user
DB_PASSWORD=changeme
# Only needed for hosts that require SSL (e.g. Neon) — leave blank for local/Docker.
DB_SSLMODE=

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=changeme-secret-key
# Comma-separated list of origins allowed to call the API (browser CORS)
CORS_ALLOW_ORIGINS=http://localhost:5173

# HSK Wordlist API (snapshot-only — no live connection during analysis)
HSK_WORDLIST_API_URL=https://your-flashcard-app.com/api/hsk-words
HSK_WORDLIST_API_KEY=

# Whisper
WHISPER_MODEL=medium
# Options: tiny, base, small, medium, large (larger = more accurate, slower)

# Vercel + Neon (see wiki/deploy-vercel.md) — set these in the Vercel
# project's env vars, not here. For the *running* API use Neon's pooled
# ("-pooler") host with DB_SSLMODE=require; for one-off batch loads
# (etl/load_word_counts.py) use Neon's direct (non-pooled) host instead.
